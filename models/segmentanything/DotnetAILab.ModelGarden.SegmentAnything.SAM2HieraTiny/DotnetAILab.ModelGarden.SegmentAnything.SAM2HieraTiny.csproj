<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>DotnetAILab.ModelGarden.SegmentAnything.SAM2HieraTiny</PackageId>
    <Description>SAM2 Hiera-Tiny segment anything model package. Segments any object given point or box prompts. Model auto-downloads on first use via ModelPackages SDK.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="ModelPackages" Version="0.1.0-preview.15" />
    <PackageReference Include="MLNet.ImageInference.Onnx" Version="0.1.0-preview.1" />
  </ItemGroup>
  <ItemGroup>
    <None Include="build\DotnetAILab.ModelGarden.SegmentAnything.SAM2HieraTiny.props" Pack="true" PackagePath="build\" />
    <None Include="build\DotnetAILab.ModelGarden.SegmentAnything.SAM2HieraTiny.targets" Pack="true" PackagePath="build\" />
  </ItemGroup>
</Project>
