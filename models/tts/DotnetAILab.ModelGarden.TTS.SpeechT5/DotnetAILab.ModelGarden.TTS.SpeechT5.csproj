<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>DotnetAILab.ModelGarden.TTS.SpeechT5</PackageId>
    <Description>SpeechT5 text-to-speech model package. Multi-model architecture (~643MB). Model auto-downloads on first use via ModelPackages SDK.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="ModelPackages" Version="0.1.0-preview.15" />
    <PackageReference Include="MLNet.AudioInference.Onnx" Version="0.1.0-preview.2" />
  </ItemGroup>
  <ItemGroup>
    <None Include="build\DotnetAILab.ModelGarden.TTS.SpeechT5.props" Pack="true" PackagePath="build\" />
    <None Include="build\DotnetAILab.ModelGarden.TTS.SpeechT5.targets" Pack="true" PackagePath="build\" />
  </ItemGroup>
</Project>
